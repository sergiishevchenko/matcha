FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:password@localhost/matcha_db
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
UPLOAD_FOLDER=./app/uploads
MAX_CONTENT_LENGTH=5242880

# Google OAuth (optional - for "Sign in with Google")
# Get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional - for "Continue with GitHub")
# Get credentials at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 42 Intra OAuth (optional)
# Create app at https://profile.intra.42.fr/oauth/applications
INTRA42_CLIENT_ID=
INTRA42_CLIENT_SECRET=
